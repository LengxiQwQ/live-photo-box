<Application
    x:Class="LivePhotoBox.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="CyberCyanBrush" Color="#00E5FF"/>
            <SolidColorBrush x:Key="CyberPurpleBrush" Color="#B388FF"/>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF" Opacity="0.9"/>
                    <SolidColorBrush x:Key="PageStatusBarBackgroundBrush" Color="#FFF7F7F7" Opacity="0.98"/>
                    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E5E5E5"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <!-- Dark theme: use true dark colors -->
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF1E1E1E" Opacity="0.95"/>
                    <SolidColorBrush x:Key="PageStatusBarBackgroundBrush" Color="#FF1E1E1E" Opacity="0.98"/>
                    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3D3D3D"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource LayerOnAcrylicFillColorDefault}" Opacity="0.8"/>
                    <SolidColorBrush x:Key="PageStatusBarBackgroundBrush" Color="{ThemeResource SolidBackgroundFillColorBase}" Opacity="0.98"/>
                    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E5E5E5"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>