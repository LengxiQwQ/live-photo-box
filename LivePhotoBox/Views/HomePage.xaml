<Page
    x:Class="LivePhotoBox.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="40,24,40,0">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Center" Margin="0,0,0,40">

            <Grid x:Name="BannerRoot" Height="350" Margin="0,8,0,8" CornerRadius="12">
                <Image x:Name="BannerImage"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       CacheMode="BitmapCache" />
                <Border CornerRadius="12" Background="#22000000"/>
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,-24,0,0">
                    <TextBlock x:Name="HeroTitleShadow"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="#44000000"
                               FontFamily="Microsoft YaHei UI"
                               CharacterSpacing="80"
                               Margin="2,3,0,0"/>
                    <TextBlock x:Name="HeroTitleText"
                               x:Uid="HomePage_HeroTitle"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               FontFamily="Microsoft YaHei UI"
                               CharacterSpacing="80"/>
                </Grid>
            </Grid>

            <TextBlock x:Uid="HomePage_HeroSubtitle"
                       FontSize="16" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontFamily="Microsoft YaHei UI"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontWeight="Light"
                       Margin="0,0,0,8"/>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="32" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE916;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock x:Uid="HomePage_WelcomeTitle" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>
                    <TextBlock x:Uid="HomePage_Intro1" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Uid="HomePage_Intro2" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <TextBlock x:Uid="HomePage_CoreFeaturesTitle" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI" Margin="0,16,0,-8"/>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE710;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="实况照片合成" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="功能简介：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="将静态图片与视频无缝结合，生成一张能在各设备上灵动显示的实况照片（Live Photo）。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="如何使用：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="将准备好的图片和视频文件配对导入，点击“开始合成”，剩下的交给我们。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8A4;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="实况照片拆分" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="功能简介：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="将现有的实况照片进行无损解包，提取出原始的静态画面与动态视频。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="如何使用：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="拖入你的实况照片，一键即可分离出独立的图像和视频文件。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE90F;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="缩略图修复" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="功能简介：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="修复因跨平台传输导致的实况照片不被识别、元数据丢失或缩略图显示异常等问题。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="如何使用：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="选择遇到问题的实况照片，程序会自动重构并修复底层元数据，让照片恢复正常。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE7C5;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="主图切换" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                            <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="开发中 🚧" FontSize="12" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="功能简介：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="自由更改实况照片的封面主图，从动态画面中挑出最完美的一刻作为静态展示。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="如何使用：" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="敬请期待！我们正在快马加鞭地为你打造此功能，很快就能与你见面。" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="HomePage_TipLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Uid="HomePage_TipText"
                               Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>