<Page
    x:Class="LivePhotoBox.Views.SplitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:LivePhotoBox.Models"
    xmlns:converters="using:LivePhotoBox.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Page.Resources>

    <Grid Padding="12,0,0,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Expander Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                  IsExpanded="{x:Bind ViewModel.IsSplitDirectoryPanelOpen, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  Background="{ThemeResource CardBackgroundBrush}"
                  CornerRadius="8"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="1">

            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Height="32">
                    <FontIcon Glyph="&#xE8B5;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock x:Uid="SplitPage_ConfigHeader" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Expander.Header>

            <Expander.Content>
                <StackPanel Spacing="12" Padding="0,4,0,0">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="SplitPage_InputLabel" VerticalAlignment="Center" FontWeight="SemiBold" Width="75"/>
                        <TextBox x:Uid="SplitPage_InputBox" Grid.Column="1" Text="{x:Bind ViewModel.SplitInputDirectory, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <Button x:Uid="SplitPage_BrowseBtn1" Grid.Column="2" Click="BrowseInput_Click"/>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="SplitPage_OutputLabel" VerticalAlignment="Center" FontWeight="SemiBold" Width="75"/>
                        <TextBox x:Uid="SplitPage_OutputBox" Grid.Column="1" Text="{x:Bind ViewModel.SplitOutputDirectory, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <Button x:Uid="SplitPage_BrowseBtn2" Grid.Column="2" Click="BrowseOutput_Click"/>
                    </Grid>

                    <MenuFlyoutSeparator Margin="0,4"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Uid="SplitPage_StatQueued" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.SplitQueuedCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Uid="SplitPage_StatRecognized" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.SplitRecognizedCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Uid="SplitPage_StatSkipped" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.SplitSkippedCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Uid="SplitPage_FormatLabel" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ComboBox Width="180"
                                      SelectedIndex="{x:Bind ViewModel.SelectedSplitFormatIndex, Mode=TwoWay}"
                                      VerticalAlignment="Center">
                                <ComboBoxItem x:Uid="SettingsPage_SplitFormat_MP4"/>
                                <ComboBoxItem x:Uid="SettingsPage_SplitFormat_MOV"/>
                            </ComboBox>
                            <Button x:Uid="SplitPage_ScanBtn"
                                    Command="{x:Bind ViewModel.ScanSplitDirectoryCommand}"
                                    Height="32"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Expander.Content>
        </Expander>

        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Padding="16,12,16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                    <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                        <Run x:Uid="SplitPage_QueueProgress"/>
                        <Run Text="{x:Bind ViewModel.SplitProgressText, Mode=OneWay}"/>
                    </TextBlock>
                    <ProgressBar Value="{x:Bind ViewModel.SplitProgress, Mode=OneWay}" Maximum="100" Height="4" CornerRadius="2" Foreground="{ThemeResource CyberCyanBrush}" MaxWidth="400" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Margin="0,0,12,0"
                            Content="{x:Bind ViewModel.SplitClearBtnText, Mode=OneWay}"
                            Command="{x:Bind ViewModel.ClearSplitQueueCommand}"
                            Width="100" Height="36"/>

                    <Button Content="{x:Bind ViewModel.SplitActionBtnText, Mode=OneWay}"
                            Command="{x:Bind ViewModel.StartSplitCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="120" Height="36"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" CornerRadius="8" Background="{ThemeResource CardBackgroundBrush}" Padding="12">
            <ListView ItemsSource="{x:Bind ViewModel.SplitTasks}" SelectionMode="None" ShowsScrollingPlaceholders="False">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel AreStickyGroupHeadersEnabled="False" CacheLength="2" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.Header>
                    <Grid Padding="12,0,12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="2.2*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Uid="SplitPage_ColSeq" Grid.Column="0" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="SplitPage_ColSource" Grid.Column="1" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="SplitPage_ColSize" Grid.Column="2" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="SplitPage_ColProgress" Grid.Column="3" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="SplitPage_ColStatus" Grid.Column="4" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="SplitPage_ColDetails" Grid.Column="5" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,6"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LivePhotoSplitTask">
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10,12,10">
                            <Grid ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="2.2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{x:Bind Index}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8B5;" Foreground="#60A5FA" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind SourceFileName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{x:Bind FileSize}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind ProgressText}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind Status}" Foreground="{x:Bind Status, Converter={StaticResource StatusToColorConverter}, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind Details}" VerticalAlignment="Center" TextWrapping="Wrap" MaxLines="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
