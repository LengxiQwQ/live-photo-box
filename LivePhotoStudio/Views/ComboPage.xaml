<Page
    x:Class="LivePhotoStudio.Views.ComboPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:LivePhotoStudio.Models"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <Grid Padding="12,0,0,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" Background="{ThemeResource CardBackgroundBrush}" Padding="16">
            <StackPanel Spacing="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="输入目录:" VerticalAlignment="Center" FontWeight="SemiBold" Width="65"/>
                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.InputDirectory, Mode=TwoWay}" PlaceholderText="请选择包含照片和视频的源文件夹" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="浏览..." Click="BrowseInput_Click"/>
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="输出目录:" VerticalAlignment="Center" FontWeight="SemiBold" Width="65"/>
                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay}" PlaceholderText="请选择生成后的实况照片保存路径" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="浏览..." Click="BrowseOutput_Click"/>
                </Grid>

                <MenuFlyoutSeparator Margin="0,4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="扫描实况照片" 
                            Command="{x:Bind ViewModel.ScanDirectoryCommand}" 
                            IsEnabled="{x:Bind ViewModel.IsNotProcessing, Mode=OneWay}"
                            Height="32" VerticalAlignment="Center"
                            Margin="0,0,16,0"/>

                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{x:Bind ViewModel.IsMultiThreadEnabled, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsNotProcessing, Mode=OneWay}"
                                  OffContent="单线程" OnContent="多线程"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,0"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="配对成功 :" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalPairsCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="单独照片 :" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.StandaloneImagesCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="单独视频 :" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.StandaloneVideosCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                <TextBlock FontWeight="SemiBold" FontSize="13">
                    <Run Text="当前队列进度："/>
                    <Run Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"/>
                </TextBlock>
                <ProgressBar Value="{x:Bind ViewModel.ComboProgress, Mode=OneWay}" Maximum="100" Height="4" CornerRadius="2" Foreground="{ThemeResource CyberCyanBrush}" MaxWidth="400" HorizontalAlignment="Left"/>
            </StackPanel>

            <Button Grid.Column="1" Margin="0,0,12,0"
                    Content="{x:Bind ViewModel.SecondaryBtnText, Mode=OneWay}" 
                    Command="{x:Bind ViewModel.ToggleSecondaryActionCommand}" 
                    Width="100" Height="36"/>

            <Grid Grid.Column="2">
                <Button Content="{x:Bind ViewModel.ActionBtnText, Mode=OneWay}" 
                        Command="{x:Bind ViewModel.ToggleProcessCommand}" 
                        Visibility="{x:Bind InverseBoolToVisibility(ViewModel.IsProcessing), Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}" 
                        Width="120" Height="36"/>

                <Button Content="{x:Bind ViewModel.ActionBtnText, Mode=OneWay}" 
                        Command="{x:Bind ViewModel.ToggleProcessCommand}" 
                        Visibility="{x:Bind BoolToVisibility(ViewModel.IsProcessing), Mode=OneWay}"
                        Foreground="White" BorderBrush="#EF4444" BorderThickness="1" Background="#EF4444"
                        Width="120" Height="36">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#DC2626"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#DC2626"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#B91C1C"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#B91C1C"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>

        <Border Grid.Row="2" CornerRadius="8" Background="{ThemeResource CardBackgroundBrush}" Padding="12">
            <ListView ItemsSource="{x:Bind ViewModel.ComboTasks}" SelectionMode="None" ShowsScrollingPlaceholders="False">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel AreStickyGroupHeadersEnabled="False" CacheLength="2" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.Header>
                    <Grid Padding="12,0,12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2.5*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="序号" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>

                        <Button Grid.Column="1" Grid.ColumnSpan="2" Command="{x:Bind ViewModel.SortCommand}" CommandParameter="Name" Background="Transparent" BorderThickness="0" Padding="0,4,8,4" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="文件组" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.NameSortIcon, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" Command="{x:Bind ViewModel.SortCommand}" CommandParameter="Size" Background="Transparent" BorderThickness="0" Padding="0,4,8,4" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="大小" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.SizeSortIcon, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Command="{x:Bind ViewModel.SortCommand}" CommandParameter="Status" Background="Transparent" BorderThickness="0" Padding="0,4,8,4" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="状态" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.StatusSortIcon, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </ListView.Header>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,6"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LivePhotoTask">
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="6" 
                                Padding="12,8,12,8">
                            <Grid ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{x:Bind Index}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <Border Grid.Column="1" Width="46" Height="46" CornerRadius="6" Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,10,0">
                                    <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                    <Button Click="FileGroupButton_Click" Tag="{x:Bind ImagePath}" Background="Transparent" BorderThickness="0" Padding="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" CornerRadius="4">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#B91C1C"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#991B1B"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="6" Height="20">
                                            <FontIcon Glyph="&#xE91B;" Foreground="#F97316" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock FontSize="13" VerticalAlignment="Center" Text="{x:Bind DisplayImageName}" ToolTipService.ToolTip="{x:Bind ImageFileName}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="FileGroupButton_Click" Tag="{x:Bind VideoPath}" Background="Transparent" BorderThickness="0" Padding="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" CornerRadius="4">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#B91C1C"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#991B1B"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="6" Height="20">
                                            <FontIcon Glyph="&#xE714;" Foreground="#A855F7" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock FontSize="13" VerticalAlignment="Center" Text="{x:Bind DisplayVideoName}" ToolTipService.ToolTip="{x:Bind VideoFileName}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock Height="20" FontSize="13" VerticalAlignment="Center" Text="{x:Bind ImageSize}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                    <TextBlock Height="20" FontSize="13" VerticalAlignment="Center" Text="{x:Bind VideoSize}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="4" 
                                           Text="{x:Bind Details, Mode=OneWay}" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           TextWrapping="Wrap" 
                                           MaxLines="3" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>