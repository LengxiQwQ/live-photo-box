<Page
    x:Class="LivePhotoStudio.Views.ComboPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:LivePhotoStudio.Models"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <Grid Padding="12,0,0,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" Background="{ThemeResource CardBackgroundBrush}" Padding="16">
            <StackPanel Spacing="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="输入目录:" VerticalAlignment="Center" FontWeight="SemiBold" Width="65"/>
                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.InputDirectory, Mode=TwoWay}" PlaceholderText="请选择包含照片和视频的源文件夹" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="浏览..." Click="BrowseInput_Click"/>
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="输出目录:" VerticalAlignment="Center" FontWeight="SemiBold" Width="65"/>
                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay}" PlaceholderText="请选择生成后的实况照片保存路径" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="浏览..." Click="BrowseOutput_Click"/>
                </Grid>

                <MenuFlyoutSeparator Margin="0,4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="扫描实况照片" 
                            Command="{x:Bind ViewModel.ScanDirectoryCommand}" 
                            IsEnabled="{x:Bind ViewModel.IsNotProcessing, Mode=OneWay}"
                            Height="32" VerticalAlignment="Center"
                            Margin="0,0,16,0"/>

                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{x:Bind ViewModel.IsMultiThreadEnabled, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsNotProcessing, Mode=OneWay}"
                                  OffContent="单线程" OnContent="多线程"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,0"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="配对成功 :" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalPairsCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="单独照片 :" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.StandaloneImagesCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="单独视频 :" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.StandaloneVideosCount, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                <TextBlock FontWeight="SemiBold" FontSize="13">
                    <Run Text="当前队列进度："/>
                    <Run Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"/>
                </TextBlock>
                <ProgressBar Value="{x:Bind ViewModel.ComboProgress, Mode=OneWay}" Maximum="100" Height="4" CornerRadius="2" Foreground="{ThemeResource CyberCyanBrush}" MaxWidth="400" HorizontalAlignment="Left"/>
            </StackPanel>

            <Button Grid.Column="1" Margin="0,0,12,0"
                    Content="清空列表" 
                    Command="{x:Bind ViewModel.ClearListCommand}" 
                    IsEnabled="{x:Bind ViewModel.IsNotProcessing, Mode=OneWay}"
                    Width="100" Height="36"/>

            <Button Grid.Column="2" 
                    Content="{x:Bind ViewModel.ActionBtnText, Mode=OneWay}" 
                    Command="{x:Bind ViewModel.ToggleProcessCommand}" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Width="120" Height="36"/>
        </Grid>

        <Border Grid.Row="2" CornerRadius="8" Background="{ThemeResource CardBackgroundBrush}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Padding="12,0,8,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="3.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="序号" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Grid.Column="1" Text="文件组" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Grid.Column="2" Text="进度" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Grid.Column="3" Text="状态" FontWeight="SemiBold" FontSize="13"/>
                </Grid>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ComboTasks}" SelectionMode="None" Margin="0,8,0,0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:LivePhotoTask">
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="6" 
                                    Padding="12,10,8,10">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="3.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{x:Bind Index}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                        <TextBlock FontSize="13">
                                            <Run Text="[图] " Foreground="#10B981" FontWeight="Bold"/>
                                            <Run Text="{x:Bind DisplayImageName}" ToolTipService.ToolTip="{x:Bind ImageFileName}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="13">
                                            <Run Text="[视] " Foreground="#6366F1" FontWeight="Bold"/>
                                            <Run Text="{x:Bind DisplayVideoName}" ToolTipService.ToolTip="{x:Bind VideoFileName}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <ProgressBar Grid.Column="2" 
                                                 Value="{x:Bind Progress, Mode=OneWay}" 
                                                 Maximum="100" 
                                                 VerticalAlignment="Center" 
                                                 Height="14" 
                                                 CornerRadius="7" 
                                                 Margin="0,0,24,0" />

                                    <TextBlock Grid.Column="3" Text="{x:Bind Details, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>